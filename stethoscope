#!/usr/bin/env python3
"""
stethoscope — vital signs for your Mac: a machine's sense of its own
internal state.

A machine-health observability layer: structured probes over macOS's native
introspection surfaces, presented for humans (CLI/TUI) and consumable by
agents. Each subsystem is a "scope" — a namespace of commands backed by a
reusable data layer in scopes/<name>.py.

  stethoscope disk <cmd>      per-process disk I/O, holds, eject blockers
  stethoscope cpu <cmd>       per-process CPU utilization and wakeups
  stethoscope memory <cmd>    per-process footprint and leak watching
  stethoscope battery <cmd>   power drain and battery health
  stethoscope smart [disk]    drive health, wear, and life expectancy
  stethoscope checkup         one-shot full-body exam across every scope
  stethoscope triage          anomaly diagnosis across baselines and live vitals
  stethoscope anomaly <cmd>   individual anomaly detectors
  stethoscope record          record machine-health samples to SQLite
  stethoscope history         query recorded samples and baselines
  stethoscope mcp             expose the scopes as MCP tools (agent integration)

No third-party dependencies — system Python 3 only.
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))

USAGE = """stethoscope — vital signs for your Mac

usage: stethoscope <scope> [command] [args]

scopes:
  disk    per-process disk I/O visibility
            top             who is doing disk I/O now (default)
            inspect <pid>   why — live syscall trace (sudo)
            holds <pid>     what files a process holds open
            busy <volume>   which pids pin a disk ("why won't it eject")
            tui             full-screen interactive view (sudo -E)
  cpu     per-process CPU utilization and wakeups
            top             who is using the CPU now (default)
            wakeups         who is waking the CPU most
  memory  per-process footprint and leak watching
            top             who is using memory now (default)
            watch <pid>     footprint slope over time (leak trend)
  battery per-process power drain and battery health
            health          charge, cycles, capacity, condition (default)
            top             who is drawing power now
            drainers        cumulative drain since you unplugged
  smart   drive health, wear, and life expectancy
            [disk]          SMART status + wear + pre-failure warnings
  checkup one-shot full-body exam — samples every scope, prints a verdict
  triage  anomaly diagnosis: baseline deviation, leaks, runaways + live health
  anomaly individual detectors: deviation, leaks, runaway, triage
  record  launchd-friendly foreground sampler (SQLite history)
  history query recorded samples; `history baseline` computes normal
  mcp     Model Context Protocol server — the scopes as agent tools (stdio)

agent/scripting: --json --once --duration N on the sampling commands

examples:
  sudo ./stethoscope disk top
  sudo ./stethoscope cpu top
  sudo ./stethoscope disk busy "/Volumes/X9 Pro"
  sudo -E ./stethoscope disk tui
"""


SCOPES = {
    # scope name -> importable module, and its optional `tui` submodule.
    # Adding a scope is a one-liner here plus a scopes/<name>.py data layer.
    "disk": {"module": "scopes.disk", "tui": "scopes.disk_tui"},
    "cpu": {"module": "scopes.cpu"},
    "memory": {"module": "scopes.memory"},
    "battery": {"module": "scopes.battery"},
    "smart": {"module": "scopes.smart"},
    "checkup": {"module": "scopes.checkup"},
    "triage": {"module": "scopes.anomaly"},
    "anomaly": {"module": "scopes.anomaly"},
    "record": {"module": "scopes.record"},
    "history": {"module": "scopes.record"},
    "mcp": {"module": "scopes.mcp_server"},
}


def _load(dotted):
    return __import__(dotted, fromlist=["main"])


def main(argv):
    args = argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(USAGE)
        return 0

    scope = args.pop(0)
    spec = SCOPES.get(scope)
    if spec is None:
        sys.stderr.write("unknown scope: %s\n\n%s" % (scope, USAGE))
        return 2

    if args and args[0] == "tui" and spec.get("tui"):
        return _load(spec["tui"]).main()
    # scope.main expects [prog, mode, ...]; rebrand prog for its messages
    return _load(spec["module"]).main(["stethoscope %s" % scope] + args)


if __name__ == "__main__":
    sys.exit(main(sys.argv))
